# Runtime data (event store)
/data/

# Binaries and build output
*.exe
*.test
*.out
/bin/
# /dist/ içeriği ignore, TEK istisna dağıtım zip'i. Dizinin kendisini
# değil İÇERİĞİNİ ignore etmek şart (/dist/ yazarsak git dizini hiç
# taramaz ve aşağıdaki istisna çalışmaz — yaşanmış).
/dist/*
# Windows dağıtım paketi (sunucu + istemci, tek zip) commit'li:
# GitHub'dan indirip iki bilgisayarda denemek için (README §Çalıştırma).
!/dist/shardlands-windows.zip

# Coverage
*.coverprofile
coverage.*

# IDE / OS
.idea/
.vscode/
Thumbs.db

# SIRLAR VE KİMLİK BİLGİLERİ
#
# Şu an bunlardan hiçbiri depoda yok (tarandı) — bu blok ÖNLEYİCİDİR.
# Sebebi docs/secrets.md §1'de yazılı: Git'e giren sır kümeden
# silinebilir ama GEÇMİŞTEN silinemez; pratikte "sızmış" sayılır ve
# döndürülmesi gerekir. En ucuz savunma, hiç girmemesini sağlamak.
*.pem
*.key
*.crt
*.p12
*.pfx
.env
.env.*
kubeconfig
*.kubeconfig
# Vault/kind gibi araçların ürettiği yerel durum
.linkerd2/
linkerd-identity-issuer*
# Yerel deneme çıktıları
*.log
/tmp/
